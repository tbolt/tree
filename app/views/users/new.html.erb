<div class="col-lg-6 mx-auto p-4 py-md-5">
  <h1 class="mb-4">Sign Up</h1>
  <%= form_with model: @user, url: sign_up_path do |form| %>
    <%= render partial: "shared/form_errors", locals: { object: form.object } %>
    <div class="mb-3">
      <%= form.label :email, class: "form-label" %>
      <%= form.email_field :email, required: true, class: "form-control" %>
    </div>
    <div class="mb-3">
      <%= form.label :username, class: "form-label" %>
      <%= form.text_field :username, required: true, class: "form-control" %>
    </div>
    <div class="mb-3">
      <%= form.label :password, class: "form-label" %>
      <%= form.password_field :password, required: true, class: "form-control" %>
    </div>
    <div class="mb-3">
      <%= form.label :password_confirmation, class: "form-label" %>
      <%= form.password_field :password_confirmation, required: true, class: "form-control" %>
    </div>
    <%= form.submit "Sign Up", class: "btn btn-primary" %>
  <% end %>
  <div class="mt-3">
    <p>Already have an account? <%= link_to "Log in", login_path %></p>
  </div>
</div>
