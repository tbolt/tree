<div class="col-lg-8 mx-auto p-4 py-md-5">
  <div class="mb-4">
    <h1><%= @user.display_name_or_username %></h1>
    <p class="text-muted">@<%= @user.username %></p>
    <% if @user.bio.present? %>
      <div class="fs-5"><%= simple_format(@user.bio) %></div>
    <% end %>
    <div class="d-flex align-items-center gap-3 mb-3">
      <%= link_to followers_path(@user.username), class: "text-decoration-none" do %>
        <strong><%= @user.followers.count %></strong> <span class="text-muted">Followers</span>
      <% end %>
      <%= link_to following_path(@user.username), class: "text-decoration-none" do %>
        <strong><%= @user.following.count %></strong> <span class="text-muted">Following</span>
      <% end %>
    </div>
    <%= render partial: "follows/follow_button", locals: { user: @user } %>
    <p class="text-muted mt-3">Joined <%= @user.created_at.strftime("%B %Y") %></p>
    <% if current_user == @user %>
      <%= link_to "Edit Profile", edit_profile_path, class: "btn btn-outline-primary btn-sm" %>
    <% end %>
  </div>

  <h2 class="mb-3">Posts</h2>
  <div id="posts">
    <% if @posts.any? %>
      <%= render partial: "posts/post", collection: @posts, as: :post %>
    <% else %>
      <p class="text-muted">No posts yet.</p>
    <% end %>
  </div>

  <% if @next_cursor && @posts.size == 20 %>
    <div class="text-center mt-3">
      <%= link_to "Load more", profile_path(@user.username, before: @next_cursor.iso8601(6)), class: "btn btn-outline-secondary" %>
    </div>
  <% end %>
</div>
