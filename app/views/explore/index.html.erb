<div class="col-lg-8 mx-auto p-4 py-md-5">
  <h1 class="mb-4">Explore</h1>
  <% if @users.any? %>
    <div class="list-group mb-4">
      <% @users.each do |user| %>
        <div class="list-group-item">
          <div class="d-flex justify-content-between align-items-start">
            <div>
              <%= link_to profile_path(user.username), class: "text-decoration-none" do %>
                <strong><%= user.display_name_or_username %></strong>
                <span class="text-muted">@<%= user.username %></span>
              <% end %>
              <% if user.bio.present? %>
                <p class="text-muted mb-0 mt-1"><%= truncate(user.bio, length: 100) %></p>
              <% end %>
            </div>
            <%= render partial: "follows/follow_button", locals: { user: user } %>
          </div>
        </div>
      <% end %>
    </div>

    <% if @next_cursor && @users.size == 20 %>
      <div class="text-center">
        <%= link_to "Load more", explore_path(before: @next_cursor.iso8601(6)), class: "btn btn-outline-secondary" %>
      </div>
    <% end %>
  <% else %>
    <p class="text-muted">No users to discover yet.</p>
  <% end %>
</div>
