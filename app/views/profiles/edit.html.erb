<div class="col-lg-8 mx-auto p-4 py-md-5">
  <h1>Edit Profile</h1>
  <%= form_with model: @user, url: update_profile_path, method: :patch do |form| %>
    <%= render partial: "shared/form_errors", locals: { object: form.object } %>
    <div class="mb-3">
      <%= form.label :display_name, class: "form-label" %>
      <%= form.text_field :display_name, class: "form-control", maxlength: 50 %>
    </div>
    <div class="mb-3">
      <%= form.label :bio, class: "form-label" %>
      <%= form.text_area :bio, class: "form-control", maxlength: 160, rows: 3 %>
    </div>
    <%= form.submit "Save Profile", class: "btn btn-primary" %>
    <%= link_to "Back to profile", profile_path(@user.username), class: "btn btn-outline-secondary ms-2" %>
  <% end %>
</div>
