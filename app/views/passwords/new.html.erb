<div class="col-lg-6 mx-auto p-4 py-md-5">
  <h1 class="mb-4">Forgot Password</h1>
  <p class="text-muted">Enter your email and we'll send you a link to reset your password.</p>
  <%= form_with url: passwords_path, scope: :user do |form| %>
    <div class="mb-3">
      <%= form.label :email, class: "form-label" %>
      <%= form.email_field :email, required: true, class: "form-control" %>
    </div>
    <%= form.submit "Reset Password", class: "btn btn-primary" %>
  <% end %>
  <div class="mt-3">
    <p><%= link_to "Back to login", login_path %></p>
  </div>
</div>
