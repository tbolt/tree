<div class="col-lg-6 mx-auto p-4 py-md-5">
  <h1 class="mb-4">Resend Confirmation</h1>
  <p class="text-muted">Enter your email and we'll resend the confirmation instructions.</p>
  <%= form_with model: @user, url: confirmations_path do |form| %>
    <div class="mb-3">
      <%= form.label :email, class: "form-label" %>
      <%= form.email_field :email, required: true, class: "form-control" %>
    </div>
    <%= form.submit "Resend Confirmation", class: "btn btn-primary" %>
  <% end %>
  <div class="mt-3">
    <p><%= link_to "Back to login", login_path %></p>
  </div>
</div>
