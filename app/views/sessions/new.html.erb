<div class="col-lg-6 mx-auto p-4 py-md-5">
  <h1 class="mb-4">Log In</h1>
  <%= form_with url: login_path, scope: :user do |form| %>
    <div class="mb-3">
      <%= form.label :email, class: "form-label" %>
      <%= form.email_field :email, required: true, class: "form-control" %>
    </div>
    <div class="mb-3">
      <%= form.label :password, class: "form-label" %>
      <%= form.password_field :password, required: true, class: "form-control" %>
    </div>
    <div class="mb-3 form-check">
      <%= form.check_box :remember_me, class: "form-check-input" %>
      <%= form.label :remember_me, class: "form-check-label" %>
    </div>
    <%= form.submit "Sign In", class: "btn btn-primary" %>
  <% end %>
  <div class="mt-3">
    <p><%= link_to "Sign up", sign_up_path %> &middot; <%= link_to "Forgot password?", new_password_path %></p>
  </div>
</div>
