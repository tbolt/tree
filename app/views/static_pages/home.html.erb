<div class="col-lg-8 mx-auto p-4 py-md-5">
  <% if user_signed_in? %>
    <h1 class="mb-4">Feed</h1>

    <%= render partial: "posts/form", locals: { post: @post } %>

    <div id="posts">
      <% if @posts.any? %>
        <%= render partial: "posts/post", collection: @posts, as: :post %>
      <% else %>
        <p class="text-muted text-center py-4">No posts yet. Follow some people to see their posts here!</p>
      <% end %>
    </div>

    <% if @next_cursor && @posts.size == 20 %>
      <div class="text-center mt-3">
        <%= link_to "Load more", root_path(before: @next_cursor.iso8601(6)), class: "btn btn-outline-secondary" %>
      </div>
    <% end %>
  <% else %>
    <div class="d-flex align-items-center pb-2 mb-5 border-bottom">
      <img src="<%= asset_path 'tree.svg' %>" width="96px">
    </div>
    <main>
      <h1>The Social Network that doesn't track you.</h1>
      <p class="fs-5 col-md-8">Join Tree and take back your privacy and sanity. No algorithms, no invasive ads, and a reverse-chronological timeline.</p>
      <div class="mb-3">
        <%= link_to "Login", login_path, class: "btn btn-outline-primary px-4" %>
        <%= link_to "Sign up", sign_up_path, class: "btn btn-primary px-4" %>
        <div class="py-2">
          <%= link_to "Forgot my password", new_password_path %>
          <br>
          <%= link_to "Didn't receive confirmation instructions", new_confirmation_path %>
        </div>
      </div>
      <hr class="col-3 col-md-2 mb-5">
      <div class="row g-5">
        <div class="col-md-6">
          <h2>Privacy First</h2>
          <p>No tracking, no algorithms, no invasive ads. Your data stays yours.</p>
        </div>
        <div class="col-md-6">
          <h2>Open Source</h2>
          <p>Follow the <a href="https://github.com/tbolt/tree">GitHub repository</a> to keep up with the latest developments.</p>
        </div>
      </div>
    </main>
    <footer class="pt-5 my-5 text-muted border-top">
      Created by <a href="https://github.com/tbolt">@tbolt</a> &middot; &copy; 2022
    </footer>
  <% end %>
</div>
